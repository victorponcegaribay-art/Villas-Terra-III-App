function loadData(){try{return JSON.parse(localStorage.getItem(STORAGE_KEY))||structuredClone(seed)}catch{return structuredClone(seed)}}
function save(){localStorage.setItem(STORAGE_KEY,JSON.stringify(data))}
function c(name){return COLORS[name]||name||"#fff"}
function tint(name,a=.14){const hex=c(name);const alpha=Math.round(a*255).toString(16).padStart(2,"0");return `background:${hex}${alpha};color:${hex};`}
function esc(s){return String(s).replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#039;")}
function now(){return new Date().toLocaleTimeString("es-MX",{hour:"2-digit",minute:"2-digit"})}
function addLog(title,detail,icon,color){data.logs.unshift({id:"log"+Date.now(),title,detail,icon,color});data.logs=data.logs.slice(0,12);save();renderAll()}

function initTabs(){
  document.querySelectorAll(".tab").forEach(tab=>{
    tab.onclick=()=>{
      document.querySelectorAll(".tab,.screen").forEach(x=>x.classList.remove("active"));
      tab.classList.add("active");
      document.getElementById(tab.dataset.tab).classList.add("active");
      scrollTo({top:0,behavior:"smooth"});
    };
  });
}

function fillSelects(){
  const opts=data.residents.map(r=>`<option value="${r.id}">${esc(r.house)} · ${esc(r.name)}</option>`).join("");
  ["incidentHouse","qrHouse","activeHouseSelect"].forEach(id=>{
    const el=document.getElementById(id); if(el){el.innerHTML=opts; el.value=data.activeResidentId;}
  });
}

function cardIcon(icon,color){return `<div class="iconBubble" style="${tint(color)}">${icon}</div>`}
function renderFocus(){
  document.getElementById("focusRow").innerHTML=focusItems.map(x=>`<button class="focus glass" style="${tint(x.color,.13)}" onclick="openFocus('${x.id}')"><span>${x.icon}</span><span>${x.title}</span></button>`).join("");
}
function renderMetrics(){
  const metrics=[
    {title:"Cuota pendiente",value:"$"+data.pendingFee,icon:"💳",color:"orange"},
    {title:"Incidencias",value:data.incidents.length,icon:"!",color:"red"},
    {title:"Visitantes",value:data.visitors.length,icon:"●●",color:"blue"},
    {title:"Agua",value:data.waterLevel+"%",icon:"💧",color:data.waterLevel<35?"red":"green"}
  ];
  document.getElementById("metricsRow").innerHTML=metrics.map(m=>`<article class="dash-card glass">${cardIcon(m.icon,m.color)}<strong>${esc(m.value)}</strong><span>${esc(m.title)}</span></article>`).join("");
}
function renderOps(){
  const html=operations.map(o=>`<button class="op glass" onclick="openOperation('${o.id}')"><i style="color:${c(o.color)}">${o.icon}</i><b>${o.value}</b><span>${o.title}</span></button>`).join("");
  document.getElementById("operationGridHome").innerHTML=html;
  document.getElementById("operationGridFull").innerHTML=html;
}
function moduleHTML(m){return `<button class="module glass" onclick="openModule('${m.id}')"><div class="moduleTop"><div class="moduleIcon" style="background:linear-gradient(135deg,${c(m.color)},rgba(255,255,255,.18));">${m.icon}</div><div style="text-align:right;font-weight:950">${esc(m.metric)}<br><span class="tag" style="${tint(m.color)}">${esc(m.status)}</span></div></div><h3>${esc(m.shortTitle)}</h3><p>${esc(m.summary)}</p><div class="moduleFoot"><span>✦ ${esc(m.aiHint)}</span><span style="color:${c(m.color)}">›</span></div></button>`}
function renderAnnouncements(){
  document.getElementById("mainAnnouncement").innerHTML=`<div class="section-head"><h2>Comunicado principal</h2><p>Resumen oficial más reciente.</p></div>${announcementHTML(announcements[0])}`;
  document.getElementById("announcementsList").innerHTML=announcements.map(announcementHTML).join("");
  document.getElementById("communicationModules").innerHTML=modules.filter(m=>["Agua","P. Civil","Seguridad"].includes(m.shortTitle)).map(moduleHTML).join("");
}
function announcementHTML(a){return `<article class="info glass"><small>${esc(a.level)} · ${esc(a.date)}</small><p style="font-weight:900;font-size:18px;margin-bottom:7px">${esc(a.title)}</p><p style="color:var(--muted)">${esc(a.body)}</p></article>`}
function renderIncidentsAndLogs(){
  document.getElementById("logList").innerHTML=data.logs.map(l=>rowHTML(l.icon,l.title,l.detail,l.color)).join("");
}
function renderAccess(){
  document.getElementById("visitorsList").innerHTML=data.visitors.map(v=>rowHTML(v.icon,v.name,`${v.detail} · ${v.time} · ${v.status}`,v.color)).join("");
  document.getElementById("cameraGrid").innerHTML=cameras.map(cam=>`<button class="module glass" onclick="openCamera('${cam.id}')"><div class="moduleTop"><div class="moduleIcon" style="background:linear-gradient(135deg,${c(cam.color)},rgba(0,0,0,.28));">${cam.icon}</div><span class="tag" style="${tint(cam.color)}">${esc(cam.ip)}</span></div><h3>${esc(cam.name)}</h3><p>${esc(cam.location)}</p><div class="moduleFoot"><span>IP local</span><span style="color:${c(cam.color)}">›</span></div></button>`).join("");
}
function rowHTML(icon,title,detail,color,id="",kind=""){
  const action=id?`onclick="open${kind}('${id}')"`:"";
  return `<button class="row glass" ${action}>${cardIcon(icon,color)}<div class="rowContent"><h3>${esc(title)}</h3><p>${esc(detail)}</p></div></button>`;
}
function renderProfile(){
  const r=data.residents.find(x=>x.id===data.activeResidentId)||data.residents[0];
  document.getElementById("profileCard").innerHTML=`<div class="profileIcon">🏠</div><h1>${esc(r.house)}</h1><p>${esc(r.name)} · ${esc(r.type)}</p><span class="login">Sesión iniciada</span>`;
  const owners=data.residents.filter(x=>x.type==="Dueño").length;
  const tenants=data.residents.filter(x=>x.type==="Inquilino").length;
  document.getElementById("registryCounters").innerHTML=[
    {t:"Dueños",v:owners,i:"🏠",c:"blue"},
    {t:"Inquilinos",v:tenants,i:"●",c:"teal"},
    {t:"Controles",v:14,i:"🔑",c:"indigo"},
    {t:"Multas",v:3,i:"📄",c:"red"}
  ].map(o=>`<article class="op glass"><i style="color:${c(o.c)}">${o.i}</i><b>${o.v}</b><span>${o.t}</span></article>`).join("");
  document.getElementById("registryRows").innerHTML=[
    rowHTML("🏠","Bitácora de residentes",`${owners} dueños · ${tenants} inquilinos · tiempo de residencia registrado`,"blue",r.id,"Resident"),
    rowHTML("🔑","Controles del portón","14 controles registrados · asignados por casa","indigo","gate","Gate"),
    rowHTML("📄","Registro de multas","3 multas registradas · seguimiento administrativo","red","fine","Fine")
  ].join("");
}
function renderAll(){fillSelects();renderFocus();renderMetrics();renderOps();renderAnnouncements();renderIncidentsAndLogs();renderAccess();renderProfile()}

function modalHero(icon,title,subtitle,color){return `<div class="heroModal" style="background:linear-gradient(135deg,${c(color)},rgba(255,255,255,.16));"><div><div class="big">${icon}</div><h2>${esc(title)}</h2><p>${esc(subtitle)}</p></div></div>`}
function info(title,value,color){return `<div class="info glass"><small>${esc(title)}</small><p>${esc(value)}</p></div>`}
function actions(list,color){return `<div class="actions">${list.map(x=>`<div class="action"><span style="color:${c(color)}">✓</span> ${esc(x)}</div>`).join("")}</div>`}
function openModal(html){document.getElementById("modalContent").innerHTML=html;document.getElementById("modalWrap").classList.add("active")}
function closeModal(){document.getElementById("modalWrap").classList.remove("active");document.getElementById("modalContent").innerHTML=""}
document.getElementById("modalWrap").onclick=e=>{if(e.target.id==="modalWrap")closeModal()};

function openFocus(id){const x=focusItems.find(o=>o.id===id);openModal(modalHero(x.icon,x.title,x.subtitle,x.color)+info("Resumen",x.detail,x.color)+actions(x.actions,x.color))}
function openOperation(id){const x=operations.find(o=>o.id===id);openModal(modalHero(x.icon,x.title,"Operación diaria",x.color)+info("Registro actual",x.value,x.color)+info("Descripción",x.detail,x.color)+actions(x.actions,x.color))}
function openModule(id){const x=modules.find(o=>o.id===id);openModal(modalHero(x.icon,x.title,x.status,x.color)+info("Descripción",x.description,x.color)+info("Resumen",x.summary,x.color)+actions(x.features,x.color))}
function openResident(id){const r=data.residents.find(o=>o.id===id)||data.residents[0];openModal(modalHero("🏠",r.house,r.type,r.color)+info("Responsable",r.name,r.color)+info("Tiempo viviendo",r.livingTime,r.color)+info("Personas",r.peopleCount,r.color)+info("Estado",r.status,r.color)+info("Observaciones",r.notes,r.color))}
function openGate(){openModal(modalHero("🔑","Controles del portón","Registro operativo","indigo")+info("Uso","Alta, baja, extravío, duplicado y casa asignada.","indigo")+actions(["Registrar control nuevo.","Dar de baja por extravío.","Asignar a casa.","Verificar funcionamiento."],"indigo"))}
function openFine(){openModal(modalHero("📄","Registro de multas","Historial administrativo","red")+info("Uso","Documenta motivo, evidencia, monto, casa y estado de pago.","red")+actions(["Registrar multa.","Adjuntar evidencia.","Marcar como pagada.","Consultar historial."],"red"))}
function openCamera(id){const cam=cameras.find(x=>x.id===id);openModal(modalHero(cam.icon,cam.name,"IP local",cam.color)+info("Ubicación",cam.location,cam.color)+info("IP",cam.ip,cam.color)+info("Nota","El celular debe estar en la misma red local. GitHub Pages usa HTTPS y algunas cámaras HTTP no se incrustan; abrir en pestaña suele funcionar mejor.",cam.color)+`<button class="primary" onclick="window.open('${cam.url}','_blank')">Abrir cámara</button>`)}
function openQRGenerated(payload,service,house,minutes){const url=`https://api.qrserver.com/v1/create-qr-code/?size=240x240&data=${encodeURIComponent(payload)}`;openModal(modalHero("▦",service,house,"black")+`<div class="qrBox"><img src="${url}" alt="QR"></div>`+info("Validez",minutes+" minutos","black")+info("Instrucción","El proveedor escanea el QR en el acceso. La casa sale a recibir o atender el servicio.","black"))}

function setActiveHouse(id){data.activeResidentId=id;save();renderAll();toast("Perfil actualizado")}
function addIncident(){
  const type=document.getElementById("incidentType").value;
  const houseId=document.getElementById("incidentHouse").value;
  const house=(data.residents.find(r=>r.id===houseId)||{}).house||"Casa";
  const detail=document.getElementById("incidentDetail").value.trim()||"Reporte registrado desde operación móvil.";
  data.incidents.unshift({id:"inc"+Date.now(),title:type,detail:`${house}: ${detail}`,priority:"Media",date:"Hoy",icon:"⚠️",color:"red"});
  addLog("Incidencia registrada",`${type} · ${house}`,"⚠️","red");
  document.getElementById("incidentDetail").value="";
  toast("Incidencia registrada");
}
function generateQR(){
  const r=data.residents.find(x=>x.id===document.getElementById("qrHouse").value)||data.residents[0];
  const service=document.getElementById("qrService").value;
  const minutes=document.getElementById("qrMinutes").value;
  const code=`VT3-${r.house.replace(/\s/g,"")}-${Date.now().toString().slice(-5)}`;
  const payload=`VILLAS TERRA III\nDESTINO: ${r.house}\nSERVICIO: ${service}\nCODIGO: ${code}\nVALIDEZ: ${minutes} minutos`;
  data.visitors.unshift({id:"vis"+Date.now(),name:service,detail:`Servicio para ${r.house} con QR temporal`,time:now(),status:"QR",icon:"▦",color:"black"});
  addLog("QR generado",`${service} para ${r.house}`,"▦","black");
  openQRGenerated(payload,service,r.house,minutes);
  toast("QR generado");
}
function exportData(){
  const blob=new Blob([JSON.stringify(data,null,2)],{type:"application/json"});
  const a=document.createElement("a");a.href=URL.createObjectURL(blob);a.download="villas-terra-iii-datos.json";a.click();URL.revokeObjectURL(a.href);
}
function resetDemo(){localStorage.removeItem(STORAGE_KEY);data=structuredClone(seed);renderAll();toast("Demo reiniciado")}
function toast(msg){const t=document.getElementById("toast");t.textContent=msg;t.classList.add("show");setTimeout(()=>t.classList.remove("show"),2200)}

initTabs();
renderAll();
</script>
