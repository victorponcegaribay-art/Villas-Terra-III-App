<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#070A12" />
  <title>Villas Terra III · Web móvil</title>
  <style>
    :root{
      --bg:#070A12;
      --ink:#F8FAFF;
      --muted:rgba(248,250,255,.66);
      --soft:rgba(248,250,255,.42);
      --card:rgba(255,255,255,.105);
      --card2:rgba(255,255,255,.16);
      --line:rgba(255,255,255,.18);
      --blue:#1FA2FF;
      --cyan:#38DDFE;
      --red:#FF4343;
      --orange:#FF9A2F;
      --green:#35D77A;
      --mint:#3EF0D0;
      --purple:#BC52FF;
      --pink:#FF3D7D;
      --yellow:#FFD60A;
      --indigo:#6D7CFF;
      --brown:#C89462;
      --teal:#19D1D1;
      --radius:28px;
      --tabH:82px;
      --safe:env(safe-area-inset-bottom,0px);
    }

    *{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      min-height:100vh;
      background:
        radial-gradient(circle at 15% -4%, rgba(31,162,255,.25), transparent 30%),
        radial-gradient(circle at 90% 18%, rgba(255,67,67,.16), transparent 32%),
        radial-gradient(circle at 10% 95%, rgba(62,240,208,.12), transparent 34%),
        linear-gradient(180deg,#05070D 0%,#070A12 45%,#05070D 100%);
      color:var(--ink);
      font-family:-apple-system,BlinkMacSystemFont,"SF Pro Display","Segoe UI",Roboto,Arial,sans-serif;
      overflow-x:hidden;
    }

    body::before{
      content:"";
      position:fixed;
      inset:0;
      pointer-events:none;
      background:
        linear-gradient(rgba(255,255,255,.018) 1px,transparent 1px),
        linear-gradient(90deg,rgba(255,255,255,.018) 1px,transparent 1px);
      background-size:34px 34px;
      mask-image:linear-gradient(to bottom,transparent,black 12%,black 78%,transparent);
    }

    button,input,select,textarea{font:inherit}
    button{border:0;background:transparent;color:inherit;cursor:pointer}
    input,select,textarea{
      width:100%;
      color:var(--ink);
      background:rgba(255,255,255,.09);
      border:1px solid var(--line);
      border-radius:18px;
      padding:14px 14px;
      outline:none;
    }
    label{display:block;margin:12px 0 7px;color:var(--muted);font-size:13px;font-weight:800}

    .app{min-height:100vh;padding-bottom:calc(var(--tabH) + var(--safe) + 16px)}
    .screen{display:none;padding:10px 18px 28px;animation:enter .25s ease}
    .screen.active{display:block}
    @keyframes enter{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}

    .topbar{
      position:sticky;top:0;z-index:30;
      display:flex;justify-content:center;align-items:center;
      height:48px;margin:0 -18px 8px;
      background:linear-gradient(180deg,rgba(7,10,18,.88),rgba(7,10,18,.55),transparent);
      backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);
      font-weight:900;
    }

    .hero{padding:8px 0 14px}
    .eyebrow{
      display:inline-flex;gap:8px;align-items:center;
      padding:7px 11px;border-radius:999px;
      background:rgba(31,162,255,.14);
      color:var(--blue);font-size:12px;font-weight:900;
      border:1px solid rgba(31,162,255,.25);
    }
    h1{
      margin:14px 0 8px;
      font-size:clamp(42px,12vw,62px);
      letter-spacing:-2.2px;line-height:.92;font-weight:950;
    }
    .subtitle{margin:0;color:var(--muted);font-size:21px;line-height:1.22;font-weight:600}

    .glass{
      position:relative;overflow:hidden;
      background:linear-gradient(145deg,rgba(255,255,255,.17),rgba(255,255,255,.075));
      border:1px solid var(--line);
      border-radius:var(--radius);
      box-shadow:0 18px 42px rgba(0,0,0,.28),inset 0 1px 0 rgba(255,255,255,.16);
      backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);
    }
    .glass::before{
      content:"";position:absolute;inset:0;pointer-events:none;
      background:
        radial-gradient(circle at 18% 0%,rgba(255,255,255,.20),transparent 28%),
        linear-gradient(145deg,rgba(255,255,255,.08),transparent 55%);
    }
    .glass>*{position:relative}

    .section{margin-top:22px}
    .section-head{margin-bottom:12px}
    .section-head h2{margin:0;font-size:25px;letter-spacing:-.7px;line-height:1.05;font-weight:950}
    .section-head p{margin:7px 0 0;color:var(--muted);font-size:15px;line-height:1.28}

    .quick-row{display:flex;gap:10px;overflow-x:auto;padding:2px 2px 5px;scrollbar-width:none}
    .quick-row::-webkit-scrollbar{display:none}
    .focus{
      flex:0 0 auto;min-width:118px;
      padding:13px 15px;border-radius:999px;
      display:flex;align-items:center;gap:9px;
      font-size:17px;font-weight:950;
      transition:.18s transform,.18s opacity;
    }
    .focus:active{transform:scale(.95);opacity:.82}

    .dash-card{
      min-width:220px;flex:0 0 220px;
      padding:16px;border-radius:28px;
    }
    .dash-card strong{display:block;font-size:34px;letter-spacing:-1px;margin:14px 0 3px}
    .dash-card span{color:var(--muted);font-size:16px;font-weight:700}
    .iconBubble{
      width:50px;height:50px;border-radius:18px;display:grid;place-items:center;
      font-size:23px;font-weight:900;
    }

    .mini-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px}
    .op{
      min-height:94px;padding:10px 7px;text-align:center;border-radius:24px;
      transition:.18s transform,.18s opacity;
    }
    .op:active{transform:scale(.94);opacity:.82}
    .op i{font-style:normal;display:block;font-size:23px;margin-bottom:7px}
    .op b{display:block;font-size:21px}
    .op span{display:block;margin-top:5px;color:var(--muted);font-size:11px;font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

    .two-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
    .module{
      min-height:190px;padding:15px;text-align:left;transition:.18s transform,.18s opacity;
    }
    .module:active{transform:scale(.97);opacity:.82}
    .moduleTop{display:flex;justify-content:space-between;gap:8px;align-items:flex-start}
    .moduleIcon{width:54px;height:54px;border-radius:20px;display:grid;place-items:center;color:white;font-size:25px}
    .tag{display:inline-flex;align-items:center;padding:5px 8px;border-radius:999px;font-size:11px;font-weight:950}
    .module h3{margin:15px 0 8px;font-size:18px;line-height:1.05}
    .module p{margin:0;color:var(--muted);font-size:13px;line-height:1.32}
    .moduleFoot{display:flex;justify-content:space-between;align-items:center;margin-top:13px;color:var(--soft);font-size:12px;font-weight:900}

    .rowList{display:grid;gap:12px}
    .row{
      width:100%;padding:15px;text-align:left;display:flex;gap:13px;align-items:flex-start;
      transition:.18s transform,.18s opacity;
    }
    .row:active{transform:scale(.98);opacity:.85}
    .row h3{margin:0;font-size:18px;line-height:1.15}
    .row p{margin:6px 0 0;color:var(--muted);font-size:14px;line-height:1.32}
    .row small{display:block;margin-top:7px;color:var(--soft);font-weight:800}
    .rowContent{flex:1;min-width:0}

    .profile{
      padding:24px;text-align:center;
    }
    .profileIcon{
      width:100px;height:100px;margin:0 auto 14px;border-radius:50%;
      display:grid;place-items:center;font-size:48px;
      color:var(--blue);background:rgba(31,162,255,.14);
      border:1px solid rgba(31,162,255,.26);
    }
    .profile h1{font-size:36px;margin:0 0 6px}
    .profile p{margin:0;color:var(--muted);font-size:17px}
    .login{display:inline-flex;margin-top:12px;padding:7px 12px;border-radius:999px;background:rgba(53,215,122,.14);color:var(--green);font-size:12px;font-weight:950}

    .formBox{padding:16px}
    .primary{
      width:100%;margin-top:14px;padding:15px;border-radius:19px;
      background:linear-gradient(135deg,var(--blue),var(--cyan));
      color:white;font-weight:950;box-shadow:0 14px 26px rgba(31,162,255,.22);
    }
    .danger{background:linear-gradient(135deg,var(--red),#ff7a45)}
    .plainBtn{background:rgba(255,255,255,.10);box-shadow:none;border:1px solid var(--line)}

    .tabbar{
      position:fixed;left:12px;right:12px;bottom:calc(10px + var(--safe));z-index:90;
      height:76px;padding:8px;display:grid;grid-template-columns:repeat(5,1fr);gap:2px;
      border-radius:38px;background:rgba(26,28,33,.78);border:1px solid rgba(255,255,255,.16);
      box-shadow:0 22px 48px rgba(0,0,0,.45);
      backdrop-filter:blur(30px);-webkit-backdrop-filter:blur(30px);
    }
    .tab{border-radius:31px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;color:rgba(255,255,255,.82)}
    .tab.active{background:rgba(255,255,255,.12);color:var(--blue)}
    .tabIcon{font-size:23px;line-height:1}.tabLabel{font-size:10.5px;font-weight:900;line-height:1}

    .modalWrap{position:fixed;inset:0;z-index:200;display:none;align-items:flex-end;background:rgba(0,0,0,.56);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px)}
    .modalWrap.active{display:flex}
    .modal{
      width:100%;max-height:88vh;overflow:auto;
      border-radius:34px 34px 0 0;padding:14px 18px calc(20px + var(--safe));
      background:linear-gradient(180deg,rgba(30,32,40,.98),rgba(12,14,20,.98));
      border:1px solid rgba(255,255,255,.18);
      box-shadow:0 -28px 60px rgba(0,0,0,.48);
    }
    .handle{width:48px;height:5px;border-radius:99px;background:rgba(255,255,255,.25);margin:0 auto 18px}
    .heroModal{min-height:174px;padding:22px;display:grid;place-items:center;text-align:center;border-radius:30px;margin-bottom:14px}
    .heroModal .big{font-size:64px;margin-bottom:10px}.heroModal h2{margin:0;font-size:26px;letter-spacing:-.6px;line-height:1.05}.heroModal p{display:inline-flex;margin:10px 0 0;padding:7px 12px;border-radius:999px;background:rgba(0,0,0,.18);color:rgba(255,255,255,.86);font-size:12px;font-weight:950}
    .info{padding:15px;margin-top:11px}
    .info small{display:block;color:var(--muted);text-transform:uppercase;letter-spacing:.35px;font-size:11px;font-weight:950;margin-bottom:7px}
    .info p{margin:0;font-size:15px;line-height:1.36}
    .actions{display:grid;gap:9px;margin-top:12px}.action{padding:12px;border-radius:17px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.10);font-size:14px;line-height:1.3}
    .qrBox{width:238px;height:238px;margin:16px auto;padding:16px;border-radius:28px;background:white;display:grid;place-items:center;box-shadow:0 18px 42px rgba(0,0,0,.28)}
    .qrBox img{width:206px;height:206px;image-rendering:pixelated}
    .toast{position:fixed;left:18px;right:18px;bottom:calc(100px + var(--safe));z-index:250;padding:13px 15px;border-radius:20px;background:rgba(35,215,122,.92);color:white;font-weight:950;display:none;box-shadow:0 16px 34px rgba(0,0,0,.38)}
    .toast.show{display:block;animation:toast .22s ease}
    @keyframes toast{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}

    @media(min-width:720px){
      .screen{max-width:560px;margin:0 auto}.tabbar{max-width:560px;margin:0 auto}
    }
  </style>
</head>

<body>
  <main class="app">
    <section id="inicio" class="screen active">
      <div class="topbar">Inicio</div>
      <header class="hero">
        <span class="eyebrow">⚡ Web móvil · Villas Terra III</span>
        <h1>Panel de administración vecinal</h1>
        <p class="subtitle">Más ligero que la app de Xcode, con la misma esencia visual: glass, accesos rápidos, QR, CCTV y perfil por casa.</p>
      </header>

      <div class="quick-row" id="focusRow"></div>

      <section class="section">
        <div class="section-head">
          <h2>Resumen vivo</h2>
          <p>Lo más importante queda arriba para reducir scroll.</p>
        </div>
        <div class="quick-row" id="metricsRow"></div>
      </section>

      <section class="section">
        <div class="section-head">
          <h2>Operación diaria</h2>
          <p>Guardia, limpieza, portón, QR, multas y reportes.</p>
        </div>
        <div class="mini-grid" id="operationGridHome"></div>
      </section>

      <section class="section" id="mainAnnouncement"></section>
    </section>

    <section id="operacion" class="screen">
      <div class="topbar">Operación</div>
      <div class="section-head">
        <h2>Centro operativo</h2>
        <p>Todo lo que pasa en la privada, ordenado por flujo de trabajo.</p>
      </div>
      <div class="mini-grid" id="operationGridFull"></div>

      <section class="section">
        <div class="section-head">
          <h2>Nuevo reporte</h2>
          <p>Registra una incidencia y actualiza la bitácora local.</p>
        </div>
        <div class="formBox glass">
          <label for="incidentType">Tipo</label>
          <select id="incidentType">
            <option>Área común sucia</option>
            <option>Lámpara apagada</option>
            <option>Mascota sin correa</option>
            <option>Ruido nocturno</option>
            <option>Portón vehicular lento</option>
            <option>Peatón / acceso obstruido</option>
          </select>

          <label for="incidentHouse">Casa relacionada</label>
          <select id="incidentHouse"></select>

          <label for="incidentDetail">Detalle</label>
          <textarea id="incidentDetail" rows="3" placeholder="Describe el reporte con precisión..."></textarea>

          <button class="primary" onclick="addIncident()">Registrar incidencia</button>
        </div>
      </section>
    </section>

    <section id="comunicados" class="screen">
      <div class="topbar">Comunicados</div>
      <div class="section-head">
        <h2>Comunicados oficiales</h2>
        <p>Agua, Protección Civil, convivencia y administración.</p>
      </div>
      <div class="rowList" id="announcementsList"></div>

      <section class="section">
        <div class="section-head"><h2>Módulos preventivos</h2><p>Información que debe estar separada del ruido del chat.</p></div>
        <div class="two-grid" id="communicationModules"></div>
      </section>
    </section>

    <section id="accesos" class="screen">
      <div class="topbar">Accesos</div>
      <div class="section-head">
        <h2>Accesos, QR y CCTV</h2>
        <p>Visitantes, comida, gas, técnicos, portón y cámaras por IP local.</p>
      </div>

      <div class="formBox glass">
        <label for="qrHouse">Casa destino</label>
        <select id="qrHouse"></select>

        <label for="qrService">Servicio</label>
        <select id="qrService">
          <option>Comida</option>
          <option>Gas</option>
          <option>Técnico internet</option>
          <option>Albañil</option>
          <option>Paquetería</option>
          <option>Proveedor externo</option>
        </select>

        <label for="qrMinutes">Validez</label>
        <select id="qrMinutes">
          <option value="30">30 minutos</option>
          <option value="45">45 minutos</option>
          <option value="60">60 minutos</option>
          <option value="120">120 minutos</option>
        </select>

        <button class="primary" onclick="generateQR()">Generar QR temporal</button>
      </div>

      <section class="section">
        <div class="section-head"><h2>Visitantes recientes</h2><p>Entradas y servicios registrados.</p></div>
        <div class="rowList" id="visitorsList"></div>
      </section>

      <section class="section">
        <div class="section-head"><h2>Cámaras locales</h2><p>Requiere estar en la misma red Wi-Fi del DVR/NVR.</p></div>
        <div class="two-grid" id="cameraGrid"></div>
      </section>
    </section>

    <section id="perfil" class="screen">
      <div class="topbar">Perfil</div>
      <div class="profile glass" id="profileCard"></div>

      <section class="section">
        <div class="formBox glass">
          <label for="activeHouseSelect">Cambiar casa con sesión iniciada</label>
          <select id="activeHouseSelect" onchange="setActiveHouse(this.value)"></select>
        </div>
      </section>

      <section class="section">
        <div class="section-head"><h2>Registro residencial</h2><p>Dueños, inquilinos, controles de portón y multas.</p></div>
        <div class="mini-grid" id="registryCounters"></div>
        <div class="rowList" id="registryRows" style="margin-top:12px"></div>
      </section>

      <section class="section">
        <div class="section-head"><h2>Bitácora</h2><p>Últimos movimientos guardados en este navegador.</p></div>
        <div class="rowList" id="logList"></div>
        <button class="primary plainBtn" onclick="exportData()">Exportar datos JSON</button>
        <button class="primary danger" onclick="resetDemo()">Reset demo</button>
      </section>
    </section>
  </main>

  <nav class="tabbar">
    <button class="tab active" data-tab="inicio"><span class="tabIcon">⌂</span><span class="tabLabel">Inicio</span></button>
    <button class="tab" data-tab="operacion"><span class="tabIcon">◎</span><span class="tabLabel">Operación</span></button>
    <button class="tab" data-tab="comunicados"><span class="tabIcon">◖</span><span class="tabLabel">Comunicados</span></button>
    <button class="tab" data-tab="accesos"><span class="tabIcon">▦</span><span class="tabLabel">Accesos</span></button>
    <button class="tab" data-tab="perfil"><span class="tabIcon">◉</span><span class="tabLabel">Perfil</span></button>
  </nav>

  <div class="modalWrap" id="modalWrap">
    <div class="modal">
      <div class="handle"></div>
      <div id="modalContent"></div>
      <button class="primary plainBtn" onclick="closeModal()">Cerrar</button>
    </div>
  </div>

  <div class="toast" id="toast"></div>

<script>
const COLORS={blue:"#1FA2FF",cyan:"#38DDFE",red:"#FF4343",orange:"#FF9A2F",green:"#35D77A",mint:"#3EF0D0",purple:"#BC52FF",pink:"#FF3D7D",yellow:"#FFD60A",indigo:"#6D7CFF",brown:"#C89462",teal:"#19D1D1",black:"#111"};
const STORAGE_KEY="villas_terra_iii_mobile_v2";

const seed={
  activeResidentId:"casa01",
  waterLevel:72,
  pendingFee:850,
  residents:[
    {id:"casa01",house:"Casa 01",name:"Familia Ponce",type:"Dueño",livingTime:"8 años",peopleCount:4,status:"Al corriente",notes:"Propietario residente. Sin adeudos activos.",color:"blue"},
    {id:"casa02",house:"Casa 02",name:"Familia López",type:"Inquilino",livingTime:"1 año 4 meses",peopleCount:3,status:"Cuota pendiente",notes:"Contrato vigente. Actualizar datos de contacto.",color:"teal"},
    {id:"casa03",house:"Casa 03",name:"Familia García",type:"Dueño",livingTime:"5 años",peopleCount:2,status:"Al corriente",notes:"Cuenta con dos controles registrados.",color:"blue"},
    {id:"casa04",house:"Casa 04",name:"Familia Hernández",type:"Inquilino",livingTime:"8 meses",peopleCount:2,status:"Revisión",notes:"Pendiente actualizar placas vehiculares.",color:"teal"}
  ],
  visitors:[
    {id:"vis01",name:"Paquetería",detail:"Entrega para Casa 03",time:"10:42",status:"Registrado",icon:"📦",color:"blue"},
    {id:"vis02",name:"Técnico hidráulico",detail:"Revisión de cuarto de bombas",time:"12:15",status:"Servicio",icon:"🔧",color:"orange"},
    {id:"vis03",name:"Comida",detail:"Pedido para Casa 01 con QR temporal",time:"14:05",status:"QR",icon:"🥡",color:"orange"}
  ],
  incidents:[
    {id:"inc01",title:"Portón vehicular lento",detail:"El motor tarda más de lo normal en cerrar. Requiere revisión preventiva.",priority:"Alta",date:"Hoy",icon:"⚠️",color:"red"},
    {id:"inc02",title:"Área común sucia",detail:"Se detectaron residuos en zona de contenedores.",priority:"Media",date:"Hoy",icon:"🗑️",color:"mint"},
    {id:"inc03",title:"Lámpara apagada",detail:"Luminaria sin funcionamiento en pasillo interior.",priority:"Media",date:"Ayer",icon:"💡",color:"yellow"}
  ],
  logs:[
    {id:"log01",title:"QR de servicio generado",detail:"Acceso temporal preparado para entrega o proveedor externo.",icon:"▦",color:"black"},
    {id:"log02",title:"Control de portón verificado",detail:"Control asignado a Casa 04 con estado activo.",icon:"🔑",color:"indigo"},
    {id:"log03",title:"CCTV acceso principal verificado",detail:"Cámara 01 lista para conexión por IP local.",icon:"🎥",color:"cyan"}
  ]
};

let data=loadData();

const focusItems=[
  {id:"agua",title:"Agua",subtitle:"Control hídrico",icon:"💧",color:"blue",detail:"Estado de cisterna, bombas, fugas, consumo y alertas preventivas.",actions:["Consultar nivel de cisterna.","Reportar fuga o desperdicio.","Revisar estado de bombas.","Generar aviso preventivo."]},
  {id:"cctv",title:"CCTV",subtitle:"Video local",icon:"🎥",color:"cyan",detail:"Acceso a 6 cámaras por IP local dentro de la red de la privada.",actions:["Abrir cámara por IP local.","Registrar verificación visual.","Consultar ubicación.","Preparar integración con DVR/NVR."]},
  {id:"seguridad",title:"Seguridad",subtitle:"Portón, QR y convivencia",icon:"🛡️",color:"red",detail:"Controles del portón, QR, rondines, peatones, mascotas, multas y Protección Civil.",actions:["Registrar control de portón.","Generar QR de servicio.","Registrar multa.","Reportar evento de seguridad."]}
];

const operations=[
